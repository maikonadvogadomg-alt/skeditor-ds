{
  "name": "sk-code-editor",
  "version": "2.0.0",
  "description": "SK Code Editor",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --publish=never",
    "build:win": "electron-builder --win --x64 --publish=never",
    "build:mac": "electron-builder --mac --x64 --arm64 --publish=never",
    "build:linux": "electron-builder --linux --x64 --publish=never"
  },
  "build": {
    "appId": "com.maikon.skeditor",
    "productName": "SK Code Editor",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "www/**/*",
      "!www/package.json",
      "!www/**/package.json",
      "!www/**/*.map"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "sign": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "SK Code Editor"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "identity": null,
      "hardenedRuntime": false
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Utility"
    },
    "compression": "normal",
    "nodeGypRebuild": false
  },
  "devDependencies": {
    "electron": "^33.4.0",
    "electron-builder": "^25.1.8"
  }
}